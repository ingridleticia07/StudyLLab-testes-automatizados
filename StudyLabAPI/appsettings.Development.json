{
  "EnvVars": {
    "API_KEY": "your_api_key_value_here",
    "POSTGRES_CONNECTION_STRING": "your_postgres_connection_string_here",
    "JWT_KEY": "your_jwt_key_here",
    "SMTP_SERVER": "your_smtp_server_here",
    "SMTP_PORT": "your_smtp_port_here",
    "SMTP_EMAIL": "your_smtp_email_here",
    "SMTP_PASSWORD": "your_smtp_password_here",
    "PASSWORD_SALT": "your_password_salt_here"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JWTParameters": {
    "Issuer": "StudyLabAPI",
    "Audience": "StudyLabWeb"
  },
  "HashParameters": {
    "DegreeOfParallelism": 4,
    "MemorySize": 8192,
    "Iterations": 12
  }
}
